# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-this-in-production

# Optional: API Keys for real data
# TWELVEDATA_API_KEY=your_twelvedata_key_here
# FINNHUB_API_KEY=your_finnhub_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Price IDs from Stripe Dashboard
STRIPE_PRICE_MONTHLY=price_monthly_xxx
STRIPE_PRICE_YEARLY=price_yearly_xxx

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Trading Dashboard <noreply@yourdomain.com>

# Admin (for trial cron)
ADMIN_SECRET_KEY=your_random_admin_secret_key