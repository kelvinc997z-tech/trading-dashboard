# Supabase Storage Configuration
# Server-side only (untuk API routes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side (jika butuh akses langsung dari browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

JWT_SECRET=your-super-secret-jwt-key-change-this
RESEND_API_KEY=re_your_resend_api_key
RESEND_VERIFY_URL=http://localhost:3000/api/auth/verify
DATABASE_URL="file:./dev.db"

# Data Source Provider Configuration
# Options: "auto" (Binance → CoinGecko fallback), "binance", "coingecko"
FETCH_PROVIDER=auto

# Coinglass API (for OHLC data)
COINGLASS_API_KEY=c0a9f49efc074d20a258475d156c1b6b

# Market Signal Generation Interval (minutes)
GENERATE_INTERVAL_MINUTES=30

# CoinAPI (alternative high-quality crypto data)
COINAPI_API_KEY=b314ce8e-d518-4a2f-9d45-2fa2083c9627

# FreeCryptoAPI (another REST data source)
FREECRYPTOAPI_API_KEY=npmtcxmmbyxqr9mylt9p

# Alchemy API (for on-chain Ethereum/EVM data)
ALCHEMY_API_KEY=hEaVOtjVp-YQGqE2QfO89

# Twelve Data API (Economic Calendar)
TWELVE_DATA_API_KEY=your_twelve_data_api_key

# CryptoQuant On-Chain Data (optional, for enhanced predictions)
# Sign up at https://portal.cryptoquant.com/
CRYPTOQUANT_API_KEY=your_cryptoquant_api_key

# Legacy APIs (optional - keep for fallback)
COINMARKETCAP_API_KEY=your_coinmarketcap_pro_api_key
FINNHUB_API_KEY=your_finnhub_api_key
MASSIVE_API_KEY=Ytej8BszgOhr6JI2ehf8BbaT0VCfBvVp

RESEND_EMAIL_FROM=alerts@yourdomain.com
CRON_SECRET=your-random-secret-here

# Doku Payment Gateway (for checkout/payment integration)
# Get credentials from: https://developer.doku.co/
DOKU_MERCHANT_CODE=your_merchant_code
DOKU_API_KEY=your_api_key
DOKU_SECRET_KEY=your_secret_key
# Base URL: use sandbox for testing, production for live
DOKU_BASE_URL=https://api-sandbox.doku.com
