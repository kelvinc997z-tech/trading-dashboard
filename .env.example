JWT_SECRET=your-super-secret-jwt-key-change-this
RESEND_API_KEY=re_your_resend_api_key
RESEND_VERIFY_URL=http://localhost:3000/api/auth/verify
DATABASE_URL="file:./dev.db"
COINMARKETCAP_API_KEY=your_coinmarketcap_pro_api_key (required for live crypto prices)
FINNHUB_API_KEY=your_finnhub_api_key (optional, for sentiment analysis)
# Alert notifications (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Resend sender domain (must be verified in Resend)
RESEND_EMAIL_FROM=alerts@yourdomain.com
# Cron job secret for alerts checker (required for production)
CRON_SECRET=your-random-secret-here
# ALERT_COOLDOWN_MS=3600000 (default 1 hour)
