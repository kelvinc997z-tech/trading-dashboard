generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  name              String?
  phone             String?
  watchlist         String    @default("[]") // JSON stringified array of symbols
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  preferences       String    @default("{}") // JSON stringified preferences: { theme, notifications, quant_ai_enabled, etc. }
  verified          Boolean   @default(false)
  verificationToken String?
  role              String    @default("free") // "free" | "pro"
  subscriptionEndsAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  trades            Trade[]
  alerts            Alert[]
  performanceMetrics PerformanceMetric[]
  payments          Payment[]
  notifications     Notification[]
  predictions       Prediction[]  // User's saved/seen predictions
}

model Trade {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  symbol          String   // XAUT, BTC, ETH, SOL, XRP, etc.
  side            String   // "buy" | "sell"
  entry           Decimal
  size            Decimal  // contract size (in units of symbol)
  exit            Decimal?
  stopLoss        Decimal?
  takeProfit      Decimal?
  pnl             Decimal? // in USD (realized)
  pnlPct          Decimal? // percentage
  status          String   @default("open") // "open" | "closed"
  date            DateTime // entry date
  exitDate        DateTime?
  notes           String?
  tags            String?  // comma-separated
  screenshotUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Alert {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  type            String   // "price" | "indicator" | "pattern"
  symbol          String?  // null = all symbols
  condition       String   // e.g., "above", "below", "cross_above", "cross_below"
  value           Decimal? // target price or indicator level
  indicator       String?  // e.g., "rsi", "macd", "bollinger"
  timeframe       String?  // "1m", "5m", "15m", "1h", "4h", "1d"
  notificationChannel String? // "email", "telegram", "push"
  isActive        Boolean  @default(true)
  lastTriggered   DateTime?
  lastCheckedAt   DateTime?
  lastCheckedPrice Decimal?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([symbol])
}

model PerformanceMetric {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  period       String   // "daily", "weekly", "monthly", "all-time"
  startDate    DateTime
  endDate      DateTime
  totalTrades  Int
  winRate      Decimal?
  avgWin       Decimal?
  avgLoss      Decimal?
  profitFactor Decimal?
  sharpeRatio  Decimal?
  sortinoRatio Decimal?
  maxDrawdown  Decimal?
  totalPnL     Decimal?
  avgTradePnL  Decimal?
  bestTrade    Decimal?
  worstTrade   Decimal?
  avgHoldingMs Int?     // average holding time in milliseconds
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, period, startDate])
  @@index([userId])
}

model CorrelationCache {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  data         String   // JSON: { "BTC/USD": { "ETH/USD": 0.75, ... }, ... }
  period       String   // "1h", "4h", "1d"
  createdAt    DateTime @default(now())

  @@unique([date, period])
}

model SentimentCache {
  id           String   @id @default(cuid())
  symbol       String
  source       String   // "news", "social", "combined"
  score        Decimal  // -1 to 1
  articles     String?  // JSON array of articles
  period       String?  // "1h", "4h", "1d"
  date         DateTime @default(now())

  @@unique([symbol, source, period, date])
  @@index([symbol])
}

// Generated predictions (cached/archived)
model Prediction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  symbol        String
  timeframe     String   // "1h", "4h", "1d"
  modelType     String   // "lstm", "xgboost", "ensemble"
  direction     String   // "buy" | "sell" | "neutral"
  confidence    Decimal  // 0-100
  price         Decimal  // predicted price
  features      String?  // JSON: feature importance/used
  expiresAt     DateTime?
  timestamp     DateTime @default(now()) // when generated
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([symbol, timeframe])
  @@index([timestamp])
  @@index([expiresAt])
}

// Cron job execution logs
model FetchLog {
  id           String   @id @default(cuid())
  jobName      String   // e.g., "fetch-ohlc", "retrain-model"
  status       String   // "success", "failed", "partial"
  symbolsFetched Int
  successful   Int
  failed       Int
  details      String?  // JSON string with detailed results
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  
  @@index([jobName, startedAt])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  plan            String   // "monthly" | "lifetime"
  amount          Decimal
  status          String   @default("pending") // "pending" | "confirmed" | "cancelled"
  method          String   @default("whatsapp") // "whatsapp" | "stripe" | "xendit"
  whatsappMessage String?
  confirmedAt     DateTime?
  confirmedBy     String?  // admin user id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, status])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "signal", "alert", "system", "price"
  title     String
  message   String
  data      String?  // JSON stringified additional data (e.g., tradeId, symbol, price)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

// OHLC Data for ML training
model OHLCData {
  id            String   @id @default(cuid())
  symbol        String
  timeframe     String   // "1h", "4h", "1d"
  timestamp     DateTime
  open          Float
  high          Float
  low           Float
  close         Float
  volume        Float

  @@unique([symbol, timeframe, timestamp])
  @@index([symbol, timeframe])
  @@index([timestamp])
}

// Technical Indicators (calculated from OHLC)
model Indicator {
  id            String   @id @default(cuid())
  symbol        String
  timeframe     String   // "1h", "4h", "1d"
  timestamp     DateTime
  // RSI
  rsi           Float?
  // MACD
  macd          Float?
  macdSignal    Float?
  macdHist      Float?
  // Moving Averages
  sma20         Float?
  sma50         Float?
  sma200        Float?
  ema12         Float?
  ema26         Float?
  // Bollinger Bands
  bollingerUpper Float?
  bollingerMiddle Float?
  bollingerLower Float?
  // Volatility
  atr           Float?
  adx           Float?
  // Stochastic
  stochK        Float?
  stochD        Float?
  // Other oscillators
  williamsR     Float?
  cci           Float?
  mfi           Float?
  // Volume
  obv           Float?

  @@unique([symbol, timeframe, timestamp])
  @@index([symbol, timeframe])
}
